{
  "branches": [
    "main",
    {
      "name": "dev",
      "prerelease": "dev"
    }
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "engine/build/libs/engine-all.jar",
            "label": "engine-all.jar"
          },
          {
            "path": "patch-tools/target/release/patch-tools",
            "label": "patch-tools-linux-x86_64"
          }
        ]
      }
    ]
  ]
}
