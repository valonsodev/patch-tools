{
  "branches": [
    "main"
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "releaseRules": [
          {
            "type": "deps",
            "release": "patch"
          },
          {
            "type": "build",
            "scope": "deps",
            "release": "patch"
          },
          {
            "type": "chore",
            "scope": "deps",
            "release": "patch"
          }
        ]
      }
    ],
    "@semantic-release/release-notes-generator",
    "./release/morphe-dependency-notes.cjs",
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "patch-tools/target/release/patch-tools",
            "label": "patch-tools-linux-x86_64"
          }
        ]
      }
    ]
  ]
}
